<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- API 28-30: enable content in display cutout area via XML attribute.
         Using the XML attribute (not the Java API) avoids the deprecated
         LAYOUT_IN_DISPLAY_CUTOUT_MODE_SHORT_EDGES constant in bytecode. -->
    <style name="Theme.TagGo" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>
